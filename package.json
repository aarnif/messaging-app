    "backend",
    "frontend"
  ],
  "scripts": {
    "backend:db:start": "npm run db:start -w backend",
    "backend:db:populate": "npm run db:populate -w backend",
    "backend:generate": "npm run generate -w backend",
    "backend:dev": "npm run dev -w backend",
    "backend:test": "npm run test -w backend",
    "backend:test:coverage": "npm run test:coverage -w backend",
    "backend:typecheck": "npm run typecheck -w backend",
    "backend:lint": "npm run lint -w backend",
    "backend:prod": "npm run prod -w backend",
